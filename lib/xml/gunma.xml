<?xml version="1.0" encoding="utf-8" ?>
<data>

    <events>
    	<event id="screenloaded">
			<click>
				<function name="begin">this</function>
			</click>
		</event>

		<event id="btnover">
			<rollover>
				<css add="btnOver">this</css>
			</rollover>
			
			<rollout>
				<css remove="btnOver">this</css>
			</rollout>
		</event>

		<event id="optionover">
			<rollover>
				<css add="optionOver">this</css>
			</rollover>
			
			<rollout>
				<css remove="optionOver">this</css>
			</rollout>

			<click>
				<css add="optionOver">this</css>
			</click>
		</event>

		<event id="imgover">
			<rollover>
				<css name="imgOver">this</css>
			</rollover>
			
			<rollout>
				<css name="imgOut">this</css>
			</rollout>

			<click>
				<css name="imgOver">this</css>
			</click>
		</event>

		<event id="select">
			<click>
				<function name="select">this</function>
			</click>
		</event>

		<event id="selectandsubmit">
			<click>
				<function name="select">this</function>
				<function name="submit">this</function>
			</click>
		</event>

		<event id="submit">
			<click>
				<function name="submit">this</function>
			</click>
		</event>

		<event id="reset">
			<click>
				<function name="reset">this</function>
			</click>
		</event>

		<event id="sca">
			<click>
				<function name="sca">this</function>
			</click>
		</event>

        <event id="loadNextQuestion">
            <click>
                <function name="loadNextQuestion">this</function>
            </click>
        </event>
		
		<event id="restart">
            <click>
                <function name="restart">this</function>
            </click>
        </event>

        <event id="sendResult">
            <click>
                <function name="sendResultJSON" />
            </click>
        </event>

        <event id="loadAnotherPage">
			<click>
				<url address="http://www.essemble.co.uk" window="true">this</url>
			</click>
		</event>
    </events>    

    <!--timer-->
    <div id="timerContainer" anim="none" class="timerContainer"/>

    <!--quiz-->
    <custom type="quiz" id="quiz" width="100%">
		<settings cheatmode="false" timer="false" radiobutton="true" radiobuttonx="10" radiobuttony="10" correctx="calc(100% - 30px)" correcty="5" attempts="1"/>
        
		
		<!-- question 1 -->
        <question id="q1" time="30" event="">

    		<image margin-bottom="30" anim="show" animtime="1" src="lib/assets/Gunma1.jpg"/>

    		<text id="question" margin-bottom="30" anim="none"><![CDATA[<p class="p_24">Around 80% of Japan’s <i>daruma</i> good luck charms are made in Gunma Prefecture. The first eye is coloured in when making a wish. When is the second one coloured in? </p>]]></text>

			<!--option 1 -->
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>On New Year’s Eve</p>]]></text>
			</option>
			
			<!--option 2 -->	
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>On New Year’s Day </p>]]></text>
			</option>

			<!--option 3 -->	
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>On your birthday </p>]]></text>
			</option>
			
			<!--option 4 -->	
			<option correct="true">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>When the wish comes true</p>]]></text>
			</option>

			<!-- feedbacks -->
			<fb id="pass" event="">	

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Correct!</p><p>The second eye is coloured in when the wish comes true. The city of Takasaki has a long association with <i>daruma</i>. </p>]]></text>
		
				<button margin-bottom="30" anim="none" event="btnover,loadNextQuestion"><![CDATA[Next question]]></button>

			</fb>
			
			<fb id="fail" event="">	

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Incorrect</p><p>The second eye is coloured in when the wish comes true. The city of Takasaki has a long association with <i>daruma</i>. </p>]]></text>
		
				<button margin-bottom="30" anim="none" event="btnover,loadNextQuestion"><![CDATA[Next question]]></button>
			</fb>
		</question>
		
		<!-- question 2 -->
        <question id="q2" time="30" event="">

    		<image margin-bottom="3" anim="show" animtime="1" src="lib/assets/Gunma2.jpg"/>
			`
    		<text id="credit" margin-bottom="10" anim="none"><![CDATA[<p class="p_8">© JNTO</p>]]></text>
 
    		<text id="question" margin-bottom="30" anim="none"><![CDATA[<p class="p_24">The mill at Tomioka is a registered UNESCO World Heritage Site. What was manufactured here? </p>]]></text>

			<!--option 1 -->
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Flour</p>]]></text>
			</option>
			
			<!--option 2 -->	
			<option correct="true">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Silk</p>]]></text>
			</option>
			
			<!--option 3 -->
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Rice</p>]]></text>
			</option>
			
			<!--option 4 -->
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Paper</p>]]></text>
			</option>
			
			<!-- feedbacks -->
			<fb id="pass" event="">	

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Correct!</p><p>Tomioka Silk Mill was established in 1872 and became an important site for Japan’s industrial revolution. </p>]]></text>
		
				<button margin-bottom="30" anim="none" event="btnover,loadNextQuestion"><![CDATA[Next question]]></button>
			</fb>
			
			<fb id="fail" event="">

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Incorrect</p><p>Tomioka Silk Mill was established in 1872 and became an important site for Japan’s industrial revolution. </p>]]></text>
		
				<button anim="none" event="btnover,loadNextQuestion"><![CDATA[Next question]]></button>
			</fb>
		</question>

		<!-- question 3 -->
        <question id="q3" time="30" event="">

    		<image margin-bottom="3" anim="show" animtime="1" src="lib/assets/Gunma3.jpg"/>
			
    		<text id="credit" margin-bottom="10" anim="none"><![CDATA[<p class="p_8">© JNTO</p>]]></text>

    		<text id="question" margin-bottom="30" anim="none"><![CDATA[<p class="p_24">A <i>bento</i> lunch shop in the town of Yokokawa became famous for serving <i>toge-no-kamameshi</i> (rice-based meals in ceramic pots). Who were its main customers?</p>]]></text>

			<!--option 1 -->
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>School children</p>]]></text>
			</option>
			
			<!--option 2 -->	
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Electricians </p>]]></text>
			</option>

			<!--option 3 -->	
			<option correct="true">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Train travellers</p>]]></text>
			</option>
			<!--/options -->
			
			<!--option 4 -->	
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Weavers</p>]]></text>
			</option>

			
			<!-- feedbacks -->
			<fb id="pass" event="">	

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Correct!</p><p>The <i>bento</i> shop was located beside a train station. One of the reasons this <i>ekiben</i> (train lunch) was popular with customers was because the ceramic pots kept the lunch warm.</p>]]></text>
		
				<button margin-bottom="30" anim="none" event="btnover,loadNextQuestion"><![CDATA[Next question]]></button>

			</fb>
			
			<fb id="fail" event="">	

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Incorrect</p><p>The <i>bento</i> shop was located beside a train station. One of the reasons this <i>ekiben</i> (train lunch) was popular with customers was because the ceramic pots kept the lunch warm. </p>]]></text>
		
				<button margin-bottom="30" anim="none" event="btnover,loadNextQuestion"><![CDATA[Next question]]></button>
			</fb>
		</question>

		<!-- question 4 -->
        <question id="q4" time="30" event="">

    		<image margin-bottom="3" anim="show" animtime="1" src="lib/assets/Gunma4.jpg"/>

    		<text id="question" margin-bottom="30" anim="none"><![CDATA[<p class="p_24">The former textile factories of Kiryu City have roofs which resemble a distinctive shape. What shape is this?</p>]]></text>

			<!--option 1 -->
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>A dome</p>]]></text>
			</option>
			
			<!--option 2 -->	
			<option correct="true">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>The teeth of a saw</p>]]></text>
			</option>

			<!--option 3 -->	
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>A silkworm</p>]]></text>
			</option>
			<!--/options -->
			
			<!--option 4 -->	
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>A butterfly</p>]]></text>
			</option>

			
			<!-- feedbacks -->
			<fb id="pass" event="">	

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Correct!</p><p>More than 200 buildings with sawtooth roofs still stand in the city, mainly used as studios, storage spaces and different types of factories.</p>]]></text>
		
				<button margin-bottom="30" anim="none" event="btnover,loadNextQuestion"><![CDATA[Next question]]></button>

			</fb>
			
			<fb id="fail" event="">	

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Incorrect</p><p>More than 200 buildings with sawtooth roofs still stand in the city, mainly used as studios, storage spaces and different types of factories.</p>]]></text>
		
				<button margin-bottom="30" anim="none" event="btnover,loadNextQuestion"><![CDATA[Next question]]></button>
			</fb>
		</question>


		<!-- question 5 -->
        <question id="q5" time="30" event="">

    		<image margin-bottom="30" anim="show" animtime="1" src="lib/assets/Gunma5.jpg"/>

    		<text id="credit" margin-bottom="10" anim="none"><![CDATA[<p class="p_8"> </p>]]></text>

    		<text id="question" margin-bottom="30" anim="none"><![CDATA[<p class="p_24">What is most commonly boiled in the geothermal hot spring waters of Kusatsu?</p>]]></text>

			<!--option 1 -->
			<option correct="true">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Eggs</p>]]></text>
			</option>
			
			<!--option 2 -->	
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Beef</p>]]></text>
			</option>

			<!--option 3 -->	
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Rice</p>]]></text>
			</option>
			
			<!--option 4 -->	
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Prawns</p>]]></text>
			</option>

			<!-- feedbacks -->
			<fb id="pass" event="">	

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Correct!</p><p><i>Onsen tamago</i> (eggs soft-boiled in hot spring water) are a local delicacy in Kusatsu. </p>]]></text>
		
				<button margin-bottom="30" anim="none" event="btnover,loadNextQuestion"><![CDATA[Finish]]></button>

			</fb>
			
			<fb id="fail" event="">	

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Incorrect</p><p><i>Onsen tamago</i> (eggs soft-boiled in hot spring water) are a local delicacy in Kusatsu. </p>]]></text>
		
				<button margin-bottom="30" anim="none" event="btnover,loadNextQuestion"><![CDATA[Finish]]></button>
			</fb>
		</question>

		<!-- question 6 -->
        <question id="q6" time="30" event="">

    		<image margin-bottom="30" anim="show" animtime="1" src="lib/assets/Gunma6.jpg"/>

    		<text id="credit" margin-bottom="10" anim="none"><![CDATA[<p class="p_8"> </p>]]></text>

    		<text id="question" margin-bottom="30" anim="none"><![CDATA[<p class="p_24">Which of the following vegetables does Gunma not grow in large quantities?</p>]]></text>

			<!--option 1 -->
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Konnyaku</p>]]></text>
			</option>
			
			<!--option 2 -->	
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Leeks</p>]]></text>
			</option>

			<!--option 3 -->	
			<option correct="true">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Persimmon</p>]]></text>
			</option>
			
			<!--option 4 -->	
			<option correct="false">
				<text margin-bottom="5" anim="none" event="optionover,selectandsubmit" class="optionBox"><![CDATA[<p>Cabbage</p>]]></text>
			</option>

			<!-- feedbacks -->
			<fb id="pass" event="">	

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Correct!</p><p>Gunma is a major producer of konnyaku, leeks and cabbage. </p>]]></text>
		
				<button margin-bottom="30" anim="none" event="btnover,loadNextQuestion"><![CDATA[Finish]]></button>

			</fb>
			
			<fb id="fail" event="">	

				<text anim="none" margin-top="30" margin-bottom="30"><![CDATA[<p class="p_24">Incorrect</p><p>Gunma is a major producer of konnyaku, leeks and cabbage. </p>]]></text>
		
				<button margin-bottom="30" anim="none" event="btnover,loadNextQuestion"><![CDATA[Finish]]></button>
			</fb>
		</question>



		
		<!--generic timeout text-->
		<timeout>
			<image margin-bottom="30" anim="top" animtime="1" animdelay="0.3" ease="Bounce.easeOut" src="https://www.uk.emb-japan.go.jp/en/quiz/lib/assets/EndImage.jpg"/>

			<text margin-bottom="30" anim="top" animtime="1" animdelay="0.2" ease="Bounce.easeOut"><![CDATA[<p class="p_42 grey">Times up!</p>]]></text>
	
			<button margin-bottom="30" anim="top" animtime="1" animdelay="0.1" ease="Bounce.easeOut" event="btnover,restart"><![CDATA[Start again]]></button>
        </timeout>


        <!--score screen-->
        <score masteryscore="80">
           <pass event="">
           		<image margin-bottom="30" anim="top" animtime="1" animdelay="0.3" ease="Bounce.easeOut" src="https://www.uk.emb-japan.go.jp/en/quiz/lib/assets/EndImage.jpg"/>

				<text margin-bottom="30" anim="top" animtime="1" animdelay="0.2" ease="Bounce.easeOut"><![CDATA[<p class="p_30">CONGRATULATIONS!</p><p class="p_24">You scored [score]%</p>]]></text>

				<text margin-bottom="30" anim="top" animtime="1" animdelay="0.2" ease="Bounce.easeOut"><![CDATA[<p>Share your result</p><a href="https://twitter.com/intent/tweet?text=I scored [passed] out of [total] on the Embassy of Japan in the UK's quiz at https://www.uk.emb-japan.go.jp/en/quiz/Gunma.html" target="_blank"><i style="font-size:32px;color:#6bc5f5;" class="fab fa-twitter-square"></i></a><a href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Fwww.uk.emb-japan.go.jp%2Fen%2Fquiz%2FGunma.html&amp;src=sdkpreparse"=I scored [passed] out of [total] on the 'name the Japanese city' quiz!&display=popup&redirect_uri=https://www.uk.emb-japan.go.jp/en/quiz/Gunma.html" class="fb-xfbml-parse-ignore" target="_blank"><i style="font-size:32px;color:#415a94;margin-left:10px" class="fab fa-facebook-square"></i></a><a href="mailto:?subject=Shared from the Japanese Gunma Quiz&body=I scored [passed] out of [total] on the 'name the Japanese city' quiz at https://www.uk.emb-japan.go.jp/en/quiz/Gunma.html" target="_blank"><i style="font-size:32px;color:#339966;margin-left:10px" class="fas fa-envelope-square"></i></a></p>]]></text>
				
				<button margin-bottom="30" anim="top" animtime="1" animdelay="0.1" ease="Bounce.easeOut" event="btnover,restart"><![CDATA[Play again?]]></button>
            </pass>
            
            <fail event="">
            	<image margin-bottom="30" anim="top" animtime="1" animdelay="0.3" ease="Bounce.easeOut" src="https://www.uk.emb-japan.go.jp/en/quiz/lib/assets/EndImage.jpg"/>

                <text margin-bottom="30" anim="top" animtime="1" animdelay="0.2" ease="Bounce.easeOut"><![CDATA[<p class="p_32">You scored [score]%</p><p class="p_24">Why not have another go?</p>]]></text>

				<text margin-bottom="30" anim="top" animtime="1" animdelay="0.2" ease="Bounce.easeOut"><![CDATA[<p>Share your result</p><a href="https://twitter.com/intent/tweet?text=I scored [passed] out of [total] on the Embassy of Japan in the UK's quiz at https://www.uk.emb-japan.go.jp/en/quiz/Gunma.html" target="_blank"><i style="font-size:32px;color:#6bc5f5;" class="fab fa-twitter-square"></i></a><a href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Fwww.uk.emb-japan.go.jp%2Fen%2Fquiz%2FGunma.html&amp;src=sdkpreparse"=I scored [passed] out of [total] on the 'Gunma' quiz!&display=popup&redirect_uri=https://www.uk.emb-japan.go.jp/en/quiz/Gunma.html" class="fb-xfbml-parse-ignore" target="_blank"><i style="font-size:32px;color:#415a94;margin-left:10px" class="fab fa-facebook-square"></i></a><a href="mailto:?subject=Shared from the Japanese Gunma quiz&body=I scored [passed] out of [total] on the 'Gunma' quiz at https://www.uk.emb-japan.go.jp/en/quiz/Gunma.html" target="_blank"><i style="font-size:32px;color:#339966;margin-left:10px" class="fas fa-envelope-square"></i></a></p>]]></text>
                    
				<button margin-bottom="30" anim="top" animtime="1" animdelay="0.1" ease="Bounce.easeOut" event="btnover,restart"><![CDATA[Play again?]]></button>
            </fail>
        </score>
    </custom>

    <!--progress bar and footer elements have reserved ids. They are optional elements and can be moved or removed if not required-->
    <div id="quiz_footer" margin-top="30" height="47" anim="hide" width="100%" text-align="center">
    	<div id="quiz_progress_outer"><div id="quiz_progress_inner"></div></div>
    	<text id="footer_score" float="left" margin-top="13" width="33.33%"><![CDATA[<p style="float:left">Score 0/[score]]</p>]]></text>
    	<text id="footer_page" float="left" margin-top="13" width="33.33%"><![CDATA[<p>Question [current]]/[total]]</p>]]></text>
    	<text id="footer_next" float="left" margin-top="5" text-align="right" width="33.33%"><![CDATA[]]></text>
    </div>


</data>

